# ── LLM 对话（OpenAI 兼容） ───────────────────────────────
# 优先级: LLM_API_KEY > AGNES_API_KEY（向后兼容）
# 默认 base URL 为 Agnes AI，可替换为任何 OpenAI 兼容端点
#   e.g. https://api.openai.com/v1
#   e.g. https://api.deepseek.com/v1
#   e.g. http://localhost:11434/v1  (Ollama)
LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE=https://apihub.agnes-ai.com/v1
LLM_MODEL=agnes-2.0-flash

# ── Agnes（生图 / 视频，暂未通用化） ────────────────────────
AGNES_API_KEY=your_agnes_api_key_here

# ── API 鉴权（部署到公网时务必设置） ─────────────────────────
# 设置后，所有 /api/* 请求需要携带 X-Internal-Key 头
# 开发环境不设置则跳过鉴权
# INTERNAL_API_KEY 和 NEXT_PUBLIC_INTERNAL_API_KEY 需设为相同值
INTERNAL_API_KEY=
NEXT_PUBLIC_INTERNAL_API_KEY=

# ── 调试日志（仅开发环境） ──────────────────────────────────
# 设为 1 开启 LLM/生图的详细请求日志
DEBUG_LLM=0
